{
	"info": {
		"_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef0123456789",
		"name": "Auth Service",
		"description": "Auth service endpoints for signup, login, token refresh, and logout. Run the Happy Path folder sequentially — login stores tokens in collection variables for use by refresh and logout.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Happy Path",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/health",
							"host": ["{{base_url}}"],
							"path": ["health"]
						},
						"description": "Returns 200 with service running message."
					},
					"response": []
				},
				{
					"name": "Signup (valid)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{test_email}}\",\n    \"password\": \"secure_password_123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/signup",
							"host": ["{{base_url}}"],
							"path": ["signup"]
						},
						"description": "Creates a new user. Returns 201 with id, email, created_at."
					},
					"response": []
				},
				{
					"name": "Login (valid)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"    const body = pm.response.json();",
									"    pm.collectionVariables.set('access_token', body.access_token);",
									"    pm.collectionVariables.set('refresh_token', body.refresh_token);",
									"    console.log('Tokens saved to collection variables.');",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{test_email}}\",\n    \"password\": \"secure_password_123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/login",
							"host": ["{{base_url}}"],
							"path": ["login"]
						},
						"description": "Authenticates user and returns access_token + refresh_token. Test script auto-saves tokens to {{access_token}} and {{refresh_token}}."
					},
					"response": []
				},
				{
					"name": "Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"    const body = pm.response.json();",
									"    pm.collectionVariables.set('access_token', body.access_token);",
									"    console.log('New access_token saved.');",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"refresh_token\": \"{{refresh_token}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/refresh",
							"host": ["{{base_url}}"],
							"path": ["refresh"]
						},
						"description": "Exchanges a valid refresh_token for a new access_token."
					},
					"response": []
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"refresh_token\": \"{{refresh_token}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/logout",
							"host": ["{{base_url}}"],
							"path": ["logout"]
						},
						"description": "Stateless logout. Returns 200 with success message. Client discards tokens."
					},
					"response": []
				}
			],
			"description": "Run in order: Health → Signup → Login → Refresh → Logout."
		},
		{
			"name": "Error Cases",
			"item": [
				{
					"name": "Signup: Invalid Email",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"not-an-email\",\n    \"password\": \"secure_password_123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/signup",
							"host": ["{{base_url}}"],
							"path": ["signup"]
						},
						"description": "Expect 400 with error=invalid_email."
					},
					"response": []
				},
				{
					"name": "Signup: Short Password",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"shortpw@example.com\",\n    \"password\": \"short\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/signup",
							"host": ["{{base_url}}"],
							"path": ["signup"]
						},
						"description": "Expect 400 with error=invalid_password."
					},
					"response": []
				},
				{
					"name": "Signup: Duplicate Email",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{test_email}}\",\n    \"password\": \"secure_password_123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/signup",
							"host": ["{{base_url}}"],
							"path": ["signup"]
						},
						"description": "Run after Signup (valid). Expect 409 with error=email_already_exists."
					},
					"response": []
				},
				{
					"name": "Login: Wrong Password",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{test_email}}\",\n    \"password\": \"wrong_password\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/login",
							"host": ["{{base_url}}"],
							"path": ["login"]
						},
						"description": "Expect 401 with error=invalid_credentials."
					},
					"response": []
				},
				{
					"name": "Refresh: Invalid Token",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"refresh_token\": \"invalid.token.here\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/refresh",
							"host": ["{{base_url}}"],
							"path": ["refresh"]
						},
						"description": "Expect 401 with error=invalid_token."
					},
					"response": []
				}
			],
			"description": "Individual error-case requests. Run independently."
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000",
			"type": "string"
		},
		{
			"key": "test_email",
			"value": "alice@example.com",
			"type": "string"
		},
		{
			"key": "access_token",
			"value": "",
			"type": "string"
		},
		{
			"key": "refresh_token",
			"value": "",
			"type": "string"
		}
	]
}
